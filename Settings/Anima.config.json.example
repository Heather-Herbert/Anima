{
  "LLMProvider": "openrouter",
  "heartbeatInterval": 300,
  "workspaceDir": "./workspace",
  "memoryMode": "session",
  "advisoryCouncil": {
    "enabled": false,
    "mode": "on_demand",
    "advisers": [
      {
        "name": "SecurityOfficer",
        "role": "Security Auditor",
        "promptFile": "Personality/Advisers/Security.md",
        "weight": 1.0,
        "temperature": 0.2,
        "model": "gpt-4-turbo-preview"
      },
      {
        "name": "Architect",
        "role": "System Architect",
        "promptFile": "Personality/Advisers/Architect.md",
        "weight": 0.8
      }
    ],
    "maxAdvisersPerCall": 3,
    "timeoutMs": 30000,
    "maxTokens": 1000,
    "parallel": true
  }
}
